if &t_Co > 1 || has("gui_running")
  syntax on
  set number
  set termguicolors

  function! ApplyColorScheme()
    if empty($SSH_CLIENT) && empty($SSH_TTY)
      let l:cs = trim(system("gsettings get org.freedesktop.appearance color-scheme 2>/dev/null"))
      if l:cs == ""
        let l:cs = trim(system("gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null"))
      endif
      if l:cs == "'prefer-dark'"
        set background=dark
      else
        set background=light
      endif
    endif

    colorscheme gruvbox
  endfunction

  call ApplyColorScheme()
  command! Rescheme call s:ApplyColorSchemeAndBackground()
  if has('nvim')
"    autocmd FocusGained * call ApplyColorScheme() " avoid as it causes flicker
    lua << EOF
  vim.uv.new_signal():start("sigusr1", vim.schedule_wrap(function()
    vim.cmd("call ApplyColorScheme()")
  end))
EOF
  endif
endif


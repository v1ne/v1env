" quick disable auto-intent magic (formerly: mis-use vim paste-toggle for it)
function! ToggleIndent()
  if &autoindent || &smartindent || &cindent || !empty(&indentexpr)
    let g:saved_indentexpr = &l:indentexpr
    setlocal noautoindent nosmartindent nocindent indentexpr=
  else
    let &l:indentexpr = get(g:, 'saved_indentexpr', '')
    setlocal autoindent smartindent
  endif
endfunction
inoremap qP <Cmd>call ToggleIndent()<CR>


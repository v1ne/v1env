## hotkeys
##########################

bindsym --locked XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym --locked XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym --locked XF86MonBrightnessDown exec --no-startup-id brightnessctl -q s '10%-'
bindsym --locked XF86MonBrightnessUp exec --no-startup-id brightnessctl -q s '10%+'
bindsym --locked XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym --locked XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioPause exec playerctl play-pause
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPrev exec playerctl previous
bindsym --locked XF86AudioStop exec playerctl stop
bindsym XF86ScreenSaver exec swaylock
bindsym $mod+Ctrl+Shift+q exec swaylock
bindsym --locked XF86PowerOff exec --no-startup-id systemctl poweroff
bindsym $mod+Ctrl+Delete exec swaymsg exit
bindsym --locked XF86Launch1 exec --no-startup-id systemctl suspend
bindsym XF86Display exec --no-startup-id darkman toggle

